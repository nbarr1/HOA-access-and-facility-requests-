# Supabase project settings
# Project dashboard: https://supabase.com/dashboard/project/mzpjkesjwkuaaqwztqnm
NEXT_PUBLIC_SUPABASE_URL=https://mzpjkesjwkuaaqwztqnm.supabase.co
# Supabase currently labels this as a publishable key. Older projects may call it an anon key;
# if you already have NEXT_PUBLIC_SUPABASE_ANON_KEY set in your deployment, the app accepts that too.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# Shared secret required by /api/email and /api/dues-sync webhook calls.
INBOUND_EMAIL_SHARED_SECRET=replace-with-a-long-random-secret

# Provider adapters. Keep manual until approved vendor API credentials are available.
AIRALLOW_ADAPTER=manual
VANTACA_ADAPTER=manual

# Required only when AIRALLOW_ADAPTER=api.
AIRALLOW_API_BASE_URL=
AIRALLOW_API_TOKEN=

# Required only when VANTACA_ADAPTER=api.
VANTACA_API_BASE_URL=
VANTACA_API_TOKEN=

# Optional local human-in-the-loop Vantaca balance reader.
HOA_APP_BASE_URL=http://localhost:3000
VANTACA_LOGIN_URL=
VANTACA_HEADLESS=false
VANTACA_BROWSER_CHANNEL=chrome
VANTACA_USERNAME_SELECTOR=
VANTACA_PASSWORD_SELECTOR=
VANTACA_SUBMIT_SELECTOR=
VANTACA_SEARCH_SELECTOR=
VANTACA_SEARCH_SUBMIT_SELECTOR=
VANTACA_RESULT_SELECTOR=
VANTACA_BALANCE_SELECTOR=
VANTACA_ADDRESS_SELECTOR=
VANTACA_NAME_SELECTOR=
VANTACA_ACCOUNT_SELECTOR=
VANTACA_EMAIL_SELECTOR=
